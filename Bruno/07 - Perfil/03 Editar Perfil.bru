meta {
  name: 03 Editar Perfil
  type: http
  seq: 3
}

put {
  url: {{baseUrl}}/users/me
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "nombre": "Tobias",
    "apellido": "Demo Editado",
    "domicilioLegal": "Av. Corrientes 1234",
    "paisOrigen": "ARG"
  }
}
