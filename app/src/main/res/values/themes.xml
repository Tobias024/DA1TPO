<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ══════════════════════════════════════════════════════════
         Base application theme — The Curator luxury dark maroon
    ══════════════════════════════════════════════════════════ -->
    <style name="Theme.SubastApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/gold</item>
        <item name="colorPrimaryVariant">@color/gold_dark</item>
        <item name="colorOnPrimary">@color/navy</item>
        <item name="colorSecondary">@color/gold_light</item>
        <item name="colorOnSecondary">@color/navy</item>
        <item name="android:colorBackground">@color/navy</item>
        <item name="colorSurface">@color/navy_card</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorError">@color/red_live</item>
        <item name="android:statusBarColor">@color/navy</item>
        <item name="android:navigationBarColor">@color/navy_card</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <!-- TextInputLayout defaults -->
        <item name="textInputStyle">@style/Widget.SubastApp.TextInputLayout</item>
    </style>

    <!-- Splash (no action bar, full-screen feel) -->
    <style name="Theme.SubastApp.Splash" parent="Theme.SubastApp">
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- ── Gold filled button ───────────────────────────────── -->
    <style name="Widget.SubastApp.Button.Gold" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/gold</item>
        <item name="android:textColor">@color/navy</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="cornerRadius">4dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- ── Gold outlined button ─────────────────────────────── -->
    <style name="Widget.SubastApp.Button.OutlinedGold" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/navy_border</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">normal</item>
        <item name="cornerRadius">4dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="backgroundTint">@color/navy_card</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- ── Gold chip / filter button ───────────────────────── -->
    <style name="Widget.SubastApp.Button.Chip" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/gold</item>
        <item name="android:textColor">@color/navy</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="cornerRadius">2dp</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
    </style>

    <!-- Inactive filter chip -->
    <style name="Widget.SubastApp.Button.ChipInactive" parent="Widget.SubastApp.Button.Chip">
        <item name="backgroundTint">@color/transparent</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="strokeColor">@color/navy_border</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- ── Card ─────────────────────────────────────────────── -->
    <style name="Widget.SubastApp.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/navy_card</item>
        <item name="strokeColor">@color/navy_border</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">4dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <!-- ── Text Input ────────────────────────────────────────── -->
    <style name="Widget.SubastApp.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/navy_input</item>
        <item name="boxStrokeColor">@color/navy_border</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">1dp</item>
        <item name="hintTextColor">@color/text_muted</item>
        <item name="android:textColorHint">@color/text_muted</item>
        <item name="boxCornerRadiusTopStart">0dp</item>
        <item name="boxCornerRadiusTopEnd">0dp</item>
        <item name="boxCornerRadiusBottomStart">0dp</item>
        <item name="boxCornerRadiusBottomEnd">0dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
    </style>

    <!-- Base TextAppearance required by dot-notation children below -->
    <style name="TextAppearance.SubastApp" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/white</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Section label (small all-caps gold) -->
    <style name="TextAppearance.SubastApp.SectionLabel" parent="TextAppearance.SubastApp">
        <item name="android:textColor">@color/gold</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- Large display heading -->
    <style name="TextAppearance.SubastApp.DisplayHeading" parent="TextAppearance.SubastApp">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:lineSpacingMultiplier">1.1</item>
    </style>

</resources>
