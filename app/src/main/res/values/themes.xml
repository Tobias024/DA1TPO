<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.SubastApp" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/gold</item>
        <item name="colorPrimaryVariant">@color/gold_dark</item>
        <item name="colorOnPrimary">@color/navy</item>
        <item name="colorSecondary">@color/gold_light</item>
        <item name="colorOnSecondary">@color/navy</item>
        <item name="android:colorBackground">@color/navy</item>
        <item name="colorSurface">@color/navy_card</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="android:statusBarColor">@color/navy</item>
        <item name="android:navigationBarColor">@color/navy_card</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Splash screen theme (no action bar) -->
    <style name="Theme.SubastApp.Splash" parent="Theme.SubastApp">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- NoActionBar for Auth and MVVM activities -->
    <style name="Theme.SubastApp.NoActionBar" parent="Theme.SubastApp">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Gold Button style -->
    <style name="Widget.SubastApp.Button.Gold" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/gold</item>
        <item name="android:textColor">@color/navy</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <!-- Outlined gold button -->
    <style name="Widget.SubastApp.Button.OutlinedGold" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/gold</item>
        <item name="android:textColor">@color/gold</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <!-- Card style -->
    <style name="Widget.SubastApp.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/navy_card</item>
        <item name="strokeColor">@color/navy_border</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <!-- Input field style -->
    <style name="Widget.SubastApp.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/navy_input</item>
        <item name="boxStrokeColor">@color/navy_border</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_muted</item>
        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusBottomEnd">10dp</item>
    </style>

</resources>
