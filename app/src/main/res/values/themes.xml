<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ══════════════════════════════════════════════════════════
         SubastAR — tema bordó + crema (Doc/CSS.md)
    ══════════════════════════════════════════════════════════ -->
    <style name="Theme.SubastAR" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryVariant">@color/brand_primary_dim</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/brand_primary</item>
        <item name="colorOnSecondary">@color/on_primary</item>
        <item name="android:colorBackground">@color/surface_cream</item>
        <item name="colorSurface">@color/surface_white</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorError">@color/red_live</item>
        <item name="android:statusBarColor">@color/brand_primary</item>
        <item name="android:navigationBarColor">@color/surface_cream</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/input_hint</item>
        <item name="textInputStyle">@style/Widget.SubastAR.TextInputLayout</item>
    </style>

    <!-- Alias para que cualquier referencia legacy a Theme.SubastApp siga funcionando -->
    <style name="Theme.SubastApp" parent="Theme.SubastAR"/>

    <!-- Splash -->
    <style name="Theme.SubastAR.Splash" parent="Theme.SubastAR">
        <item name="android:windowFullscreen">true</item>
        <item name="android:colorBackground">@color/brand_primary</item>
        <item name="android:statusBarColor">@color/brand_primary</item>
    </style>
    <style name="Theme.SubastApp.Splash" parent="Theme.SubastAR.Splash"/>

    <!-- ── Botón primario bordó (Button Danger del CSS.md) ───────────── -->
    <style name="Widget.SubastAR.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/brand_primary</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0.0</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>
    <!-- Aliases legacy para no romper layouts existentes -->
    <style name="Widget.SubastApp.Button.Gold" parent="Widget.SubastAR.Button.Primary"/>

    <!-- ── Botón outlined bordó ──────────────────────────────────────── -->
    <style name="Widget.SubastAR.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/brand_primary</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/brand_primary</item>
        <item name="android:textStyle">normal</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="backgroundTint">@color/surface_cream</item>
        <item name="android:stateListAnimator">@null</item>
    </style>
    <style name="Widget.SubastApp.Button.OutlinedGold" parent="Widget.SubastAR.Button.Outlined"/>

    <!-- ── Chip / filter ─────────────────────────────────────────────── -->
    <style name="Widget.SubastAR.Button.Chip" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/brand_primary</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
    </style>
    <style name="Widget.SubastApp.Button.Chip" parent="Widget.SubastAR.Button.Chip"/>

    <style name="Widget.SubastAR.Button.ChipInactive" parent="Widget.SubastAR.Button.Chip">
        <item name="backgroundTint">@color/input_bg</item>
        <item name="android:textColor">@color/input_hint</item>
        <item name="strokeColor">@color/input_border</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>
    <style name="Widget.SubastApp.Button.ChipInactive" parent="Widget.SubastAR.Button.ChipInactive"/>

    <!-- ── Card ─────────────────────────────────────────────────────── -->
    <style name="Widget.SubastAR.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface_white</item>
        <item name="strokeColor">@color/input_border</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">8dp</item>
        <item name="cardElevation">0dp</item>
    </style>
    <style name="Widget.SubastApp.Card" parent="Widget.SubastAR.Card"/>

    <!-- ── Text Input ───────────────────────────────────────────────── -->
    <style name="Widget.SubastAR.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/input_bg</item>
        <item name="boxStrokeColor">@color/input_border</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">1dp</item>
        <item name="hintTextColor">@color/input_hint</item>
        <item name="android:textColorHint">@color/input_hint</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
    </style>
    <style name="Widget.SubastApp.TextInputLayout" parent="Widget.SubastAR.TextInputLayout"/>

    <!-- ── Tipografía (Doc/CSS.md) ──────────────────────────────────── -->
    <style name="TextAppearance.SubastAR" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
    <style name="TextAppearance.SubastApp" parent="TextAppearance.SubastAR"/>

    <!-- Title Page (Inter 700 48sp blanco sobre bordó) -->
    <style name="TextAppearance.SubastAR.TitlePage" parent="TextAppearance.SubastAR">
        <item name="android:textColor">@color/text_on_dark</item>
        <item name="android:textSize">48sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.02</item>
        <item name="android:lineSpacingMultiplier">1.2</item>
    </style>

    <!-- Display small emphasized (Roboto 500 36sp bordó) -->
    <style name="TextAppearance.SubastAR.Display" parent="TextAppearance.SubastAR">
        <item name="android:textColor">@color/brand_primary</item>
        <item name="android:textSize">36sp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <!-- Headline small (Roboto 500 24sp negro) -->
    <style name="TextAppearance.SubastAR.Headline" parent="TextAppearance.SubastAR">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <!-- Title large (Roboto 400 22sp) -->
    <style name="TextAppearance.SubastAR.Title.Large" parent="TextAppearance.SubastAR">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <!-- Title medium (Roboto 500 16sp letterSpacing 0.15) -->
    <style name="TextAppearance.SubastAR.Title.Medium" parent="TextAppearance.SubastAR">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0.0094</item>
    </style>

    <!-- Label large (Roboto 500 14sp) -->
    <style name="TextAppearance.SubastAR.Label" parent="TextAppearance.SubastAR">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0.0071</item>
    </style>

    <!-- Body base (Inter 400 16sp) -->
    <style name="TextAppearance.SubastAR.Body" parent="TextAppearance.SubastAR">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
    </style>

    <!-- Aliases legacy (los layouts existentes los referencian) -->
    <style name="TextAppearance.SubastApp.SectionLabel" parent="TextAppearance.SubastAR.Label">
        <item name="android:textColor">@color/brand_primary</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.12</item>
    </style>
    <style name="TextAppearance.SubastApp.DisplayHeading" parent="TextAppearance.SubastAR.Display">
        <item name="android:textColor">@color/brand_primary</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:lineSpacingMultiplier">1.1</item>
    </style>

</resources>
