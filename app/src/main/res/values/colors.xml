<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ══════════════════════════════════════════════════════════
         SubastAR — paleta del Doc/CSS.md (bordó + crema)
    ══════════════════════════════════════════════════════════ -->

    <!-- Brand -->
    <color name="brand_primary">#710000</color>     <!-- bordó: botones, headlines -->
    <color name="brand_primary_dim">#5A0000</color> <!-- pressed -->
    <color name="brand_primary_light">#8A1A1A</color>
    <color name="on_primary">#FEE9E7</color>        <!-- texto sobre bordó -->

    <!-- Surfaces -->
    <color name="surface_cream">#F5ECE4</color>     <!-- fondo principal de tarjetas -->
    <color name="surface_white">#FFFFFF</color>     <!-- elevated/card -->
    <color name="scrim">#CC000000</color>

    <!-- Inputs -->
    <color name="input_bg">#D9D9D9</color>
    <color name="input_border">#9D9D9D</color>
    <color name="input_hint">#727272</color>

    <!-- Text -->
    <color name="text_primary">#000000</color>
    <color name="text_on_dark">#FFFFFF</color>
    <color name="divider_strong">#1E1E1E</color>

    <!-- ── Aliases hacia nombres legacy (para no romper layouts/drawables) ── -->
    <!-- Antes "gold/navy/etc", ahora apuntan a la nueva paleta SubastAR -->
    <color name="gold">@color/brand_primary</color>
    <color name="gold_dark">@color/brand_primary_dim</color>
    <color name="gold_light">@color/brand_primary_light</color>
    <color name="gold_subtle">#33710000</color>      <!-- 20% bordó -->

    <color name="navy">@color/surface_cream</color>          <!-- antes deepest bg -->
    <color name="navy_card">@color/surface_white</color>     <!-- antes card bg -->
    <color name="navy_input">@color/input_bg</color>
    <color name="navy_border">@color/input_border</color>
    <color name="navy_elevated">@color/surface_white</color>

    <color name="white">@color/text_on_dark</color>
    <color name="text_secondary">@color/text_primary</color>
    <color name="text_muted">@color/input_hint</color>

    <!-- ── Status (se mantienen, son funcionales) ───────────────── -->
    <color name="green_live">#4CAF50</color>
    <color name="red_live">#E84343</color>
    <color name="orange_pending">#E8A043</color>
    <color name="blue_upcoming">#6A9FD9</color>

    <!-- ── Categorías (gating por categoría — PDF) ──────────────── -->
    <color name="cat_comun">#888888</color>
    <color name="cat_especial">#4CAF50</color>
    <color name="cat_plata">#C0C0C0</color>
    <color name="cat_oro">#C9A84C</color>
    <color name="cat_platino">#E5E4E2</color>

    <!-- ── System ─────────────────────────────────────────────── -->
    <color name="transparent">#00000000</color>
    <color name="black">#FF000000</color>
</resources>
