<?xml version="1.0" encoding="utf-8"?>
<!-- Consignment / Solicitud de Subasta — matches Figma's 5th panel -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/navy">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical"
        android:background="@color/navy_card">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_previous"
            android:tint="@color/white"
            android:contentDescription="Volver"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="28dp"
            android:paddingBottom="60dp">

            <!-- "CONSIGNACIÓN DE LUJO" -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/consignacion_lujo"
                android:textColor="@color/gold"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.16"
                android:layout_marginBottom="6dp"/>

            <!-- "Solicitud de Subasta" -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/consignment_title"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:textStyle="bold"
                android:lineSpacingMultiplier="1.1"
                android:layout_marginBottom="10dp"/>

            <!-- Intro text -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/consignment_subtitle"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="28dp"/>

            <!-- ─ Detalles del Objeto ───────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.SubastApp.Card"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/detalles_objeto"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <!-- Nombre del bien -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/nombre_bien"
                        android:textColor="@color/text_muted"
                        android:textSize="9sp"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="4dp"/>
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.SubastApp.TextInputLayout"
                        android:layout_marginBottom="16dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_nombre_bien"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:textSize="14sp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Descripción detallada -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/descripcion_detallada"
                        android:textColor="@color/text_muted"
                        android:textSize="9sp"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="4dp"/>
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.SubastApp.TextInputLayout"
                        android:layout_marginBottom="16dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_descripcion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:inputType="textMultiLine"
                            android:minLines="3"
                            android:gravity="top"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Historia del objeto -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/historia_objeto"
                        android:textColor="@color/text_muted"
                        android:textSize="9sp"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="4dp"/>
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.SubastApp.TextInputLayout">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_historia"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:inputType="textMultiLine"
                            android:minLines="3"
                            android:gravity="top"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─ Galería de Activos ─────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.SubastApp.Card"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/galeria_activos"
                            android:textColor="@color/white"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/minimo_fotos"
                            android:textColor="@color/text_muted"
                            android:textSize="9sp"
                            android:letterSpacing="0.08"/>
                    </LinearLayout>

                    <!-- Photo grid (2x3) -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_photos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"/>

                    <!-- Add photo button -->
                    <LinearLayout
                        android:id="@+id/btn_add_photo"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_upload_area"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📷"
                            android:textSize="20sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FOTO PRINCIPAL"
                            android:textColor="@color/text_muted"
                            android:textSize="9sp"
                            android:letterSpacing="0.08"
                            android:layout_marginTop="3dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─ Declaraciones Legales ─────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.SubastApp.Card"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/declaraciones_legales"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="14dp"/>

                    <CheckBox
                        android:id="@+id/cb_propiedad"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/declara_propiedad"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:buttonTint="@color/gold"
                        android:lineSpacingMultiplier="1.4"
                        android:layout_marginBottom="12dp"/>

                    <CheckBox
                        android:id="@+id/cb_origen"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/declara_origen"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:buttonTint="@color/gold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─ Proceso de Depósito (info card) ───────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#3D1A0D"
                app:strokeColor="#C9A84C"
                app:strokeWidth="1dp"
                app:cardCornerRadius="4dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/proceso_deposito"
                        android:textColor="@color/gold"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/proceso_descripcion"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.5"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CTA button -->
            <Button
                android:id="@+id/btn_enviar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/enviar_solicitud"
                style="@style/Widget.SubastApp.Button.Gold"
                android:layout_marginBottom="16dp"/>

            <!-- "¿Necesita asistencia experta?" card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.SubastApp.Card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💬"
                        android:textSize="20sp"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/necesita_asistencia"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/hablar_curador"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
