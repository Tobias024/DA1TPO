<?xml version="1.0" encoding="utf-8"?>
<!-- Placeholder SubastAR (pantallas en construcción) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:background="@color/surface_cream">

    <View
        android:layout_width="48dp"
        android:layout_height="2dp"
        android:background="@color/brand_primary"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SubastAR"
        android:textColor="@color/brand_primary"
        android:textSize="36sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pantalla en construcción"
        android:textColor="@color/text_primary"
        android:textSize="16sp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Próximamente disponible"
        android:textColor="@color/input_hint"
        android:textSize="14sp"
        android:layout_marginTop="6dp"/>

    <View
        android:layout_width="48dp"
        android:layout_height="2dp"
        android:background="@color/brand_primary"
        android:layout_marginTop="24dp"/>

</LinearLayout>
