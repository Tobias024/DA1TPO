<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_cream"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Confirmación 2 / 2"
            android:textColor="@color/input_hint"
            android:textSize="14sp"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/step3_title"
            android:textColor="@color/brand_primary"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/elegir_medio_inicial"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:layout_marginBottom="20dp"/>

        <RadioGroup
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <RadioButton
                android:id="@+id/rb_cuenta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cuenta bancaria"
                android:textColor="@color/text_primary"
                android:padding="8dp"/>
            <RadioButton
                android:id="@+id/rb_tarjeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tarjeta de crédito"
                android:textColor="@color/text_primary"
                android:padding="8dp"/>
            <RadioButton
                android:id="@+id/rb_cheque"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cheque certificado"
                android:textColor="@color/text_primary"
                android:padding="8dp"/>
        </RadioGroup>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/input_border"
            android:layout_marginVertical="20dp"/>

        <CheckBox
            android:id="@+id/cb_tyc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/aceptar_tyc"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btn_finalizar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/finalizar_registro"
            style="@style/Widget.SubastAR.Button.Primary"/>
    </LinearLayout>
</ScrollView>
