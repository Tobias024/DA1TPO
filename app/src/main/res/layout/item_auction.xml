<?xml version="1.0" encoding="utf-8"?>
<!-- Auction card — matches Figma's rich auction cards with hero image placeholder,
     category/type badges, title, timer, lot count, bid and Participar button -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    style="@style/Widget.SubastApp.Card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Hero image area (Glide will load URL into this) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="148dp">

            <ImageView
                android:id="@+id/iv_auction_cover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="Imagen de la subasta"
                android:background="@color/navy_elevated"/>

            <!-- Gradient scrim over image -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/scrim_bottom"/>

            <!-- Category + type badges (top-left) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="top|start"
                android:padding="10dp">

                <TextView
                    android:id="@+id/tv_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/gold"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:background="@drawable/bg_category_badge"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:id="@+id/tv_subcategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.06"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:background="@drawable/bg_status_badge"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Timer + lot count (bottom of image) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="bottom"
                android:paddingHorizontal="10dp"
                android:paddingBottom="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_countdown"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="⏱ CIERRE: 03h:40min"
                    android:textColor="@color/white"
                    android:textSize="10sp"/>

                <TextView
                    android:id="@+id/tv_lot_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="48 LOTES"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"/>
            </LinearLayout>
                <!-- Status badge (top-right of image) -->
                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="10dp"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:background="@drawable/bg_status_badge"
                    android:textColor="@color/white"/>
            </FrameLayout>

        <!-- Content area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="14dp"
            android:paddingTop="12dp"
            android:paddingBottom="14dp">

            <!-- Title -->
            <TextView
                android:id="@+id/tv_auction_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="4dp"/>

            <!-- Location -->
            <TextView
                android:id="@+id/tv_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:drawablePadding="4dp"
                android:layout_marginBottom="2dp"/>

            <!-- Auctioneer -->
            <TextView
                android:id="@+id/tv_auctioneer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:layout_marginBottom="10dp"
                android:visibility="gone"/>

            <!-- Separator line -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/navy_border"
                android:layout_marginBottom="10dp"/>


            <!-- Bid row: "PUJA ACTUAL" label + amount + button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/puja_actual"
                        android:textColor="@color/text_muted"
                        android:textSize="8sp"
                        android:letterSpacing="0.10"/>

                    <TextView
                        android:id="@+id/tv_current_bid"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ARS 0"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Currency badge -->
                <TextView
                    android:id="@+id/tv_currency"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/navy"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:background="@drawable/bg_currency_badge"
                    android:layout_marginEnd="10dp"
                    android:visibility="gone"/>

                <Button
                    android:id="@+id/btn_participate"
                    android:layout_width="100dp"
                    android:layout_height="40dp"
                    android:text="@string/participar"
                    android:textSize="12sp"
                    style="@style/Widget.SubastApp.Button.Gold"/>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
